# === ANTHROPIC ===
ANTHROPIC_API_KEY=

# === TELEGRAM — Main Agent ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=        # Comma-separated: 123456789,987654321

# === GOOGLE AI (Gemini) ===
GOOGLE_API_KEY=

# === SECURITY ===
PIN_HASH=                          # Generate: node -e "const{createHash}=require('crypto');console.log(createHash('sha256').update('YOUR_PIN'+'solomons_key_salt').digest('hex'))"
KILL_PHRASE=                       # A memorable phrase to emergency-halt all agents
IDLE_LOCK_MINUTES=30               # Minutes of inactivity before PIN re-required
DASHBOARD_TOKEN=                   # Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# === MODELS ===
MAIN_MODEL=claude-opus-4-6         # Strongest model for main agent
AGENT_MODEL=claude-sonnet-4-6      # Sub-agents (comms, content, ops, research)
GEMINI_EXTRACT_MODEL=gemini-2.5-flash    # Memory extraction
GEMINI_EMBED_MODEL=gemini-embedding-001          # Vector embeddings (768-dim)

# === LIMITS ===
AGENT_MAX_TURNS=30
AGENT_TIMEOUT_MS=900000            # 15 minutes
COST_FOOTER_MODE=compact           # compact | verbose | cost | full | off

# === DASHBOARD ===
DASHBOARD_PORT=3000                # Localhost only (cloudflared tunnel skipped)

# === MULTI-AGENT ===
SOLOMONS_KEY_CONFIG=/home/solomon/.solomons-key   # External config dir for extra agents

# === WAR ROOM ===
DEEPGRAM_API_KEY=                  # STT — real-time transcription
CARTESIA_API_KEY=                  # TTS — per-agent voices
GROQ_API_KEY=                      # STT fallback (Groq Whisper)
ELEVENLABS_API_KEY=                # TTS fallback

# === MEETING BOT ===
PIKA_DEV_KEY=                      # Video avatar ($0.275/min)
RECALL_API_KEY=                    # Alternative voice-only provider

# === PATHS ===
PROJECT_ROOT=/home/solomon/solomons-key
STORE_PATH=/home/solomon/solomons-key/store/solomons-key.db

# === MCP ===
MCP_CONFIG_PATH=./mcp-servers.json # Path to MCP server definitions (see mcp-servers.json)
